# ─────────────────────────────────────────────────────────────────────────────
# JutJut — Environment Variables Reference
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=production          # development | production

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000                    # HTTP port the Express server listens on

# ── Database (MySQL / TiDB) ───────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl={"rejectUnauthorized":true}
DATABASE_URL=mysql://jutjut:password@127.0.0.1:3306/jutjut

# ── Auth / Sessions ───────────────────────────────────────────────────────────
# A long random string used to sign JWT session cookies.
# Generate with: openssl rand -base64 48
JWT_SECRET=replace_with_a_long_random_secret

# ── Manus OAuth ───────────────────────────────────────────────────────────────
# Provided by the Manus platform — do not change unless migrating auth providers.
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=

# ── Manus Built-in APIs (LLM, Storage, Notifications, etc.) ──────────────────
# Server-side key (never expose to the browser).
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Frontend key (safe to expose — read-only, rate-limited).
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# ── Analytics ─────────────────────────────────────────────────────────────────
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── Payments (PinPayments) ────────────────────────────────────────────────────
# Leave blank to disable payment features.
PIN_PAYMENTS_SECRET_KEY=
PIN_PAYMENTS_PUBLISHABLE_KEY=
PIN_PAYMENTS_WEBHOOK_SECRET=
# Use https://api.pinpayments.com/1 for production
PIN_PAYMENTS_BASE_URL=https://test-api.pinpayments.com/1
